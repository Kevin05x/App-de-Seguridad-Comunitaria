    app:layout_constraintTop_toTopOf=\"parent\" />\r\n\r\n        <View\r\n            android:id=\"@+id/dividerHeader\"\r\n            android:layout_width=\"match_parent\"\r\n            android:layout_height=\"1dp\"\r\n            android:background=\"@color/border_dark\"\r\n            app:layout_constraintBottom_toBottomOf=\"parent\" />\r\n    </androidx.constraintlayout.widget.ConstraintLayout>\r\n\r\n    <androidx.core.widget.NestedScrollView\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"0dp\"\r\n        android:fillViewport=\"true\"\r\n        app:layout_constraintBottom_toTopOf=\"@id/contenedorBarraInferior\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/headerPerfil\">\r\n\r\n        <androidx.constraintlayout.widget.ConstraintLayout\r\n            android:layout_width=\"match_parent\"\r\n            android:layout_height=\"wrap_content\"\r\n            android:paddingBottom=\"24dp\">\r\n\r\n            <com.google.android.material.card.MaterialCardView\r\n                android:id=\"@+id/cardUserInfo\"\r\n                android:layout_width=\"match_parent\"\r\n                android:layout_height=\"wrap_content\"\r\n                android:layout_margin=\"16dp\"\r\n                app:cardBackgroundColor=\"@color/bg_card_dark\"\r\n                app:cardCornerRadius=\"16dp\"\r\n                app:strokeColor=\"@color/border_dark\"\r\n                app:strokeWidth=\"1dp\"\r\n                app:layout_constraintTop_toTopOf=\"parent\">\r\n\r\n                <androidx.constraintlayout.widget.ConstraintLayout\r\n                    android:layout_width=\"match_parent\"\r\n                    android:layout_height=\"wrap_content\"\r\n                    android:padding=\"24dp\">\r\n\r\n                    <com.google.android.material.imageview.ShapeableImageView\r\n                        android:id=\"@+id/imgPerfil\"\r\n                        android:layout_width=\"90dp\"\r\n                        android:layout_height=\"90dp\"\r\n                        android:scaleType=\"centerCrop\"\r\n                        android:src=\"@drawable/fondo_perfil\"\r\n                        app:layout_constraintEnd_toEndOf=\"parent\"\r\n                        app:layout_constraintStart_toStartOf=\"parent\"\r\n                        app:layout_constraintTop_toTopOf=\"parent\"\r\n                        app:shapeAppearanceOverlay=\"@style/ShapeAppearance.Material3.Corner.Full\" />\r\n\r\n                    <TextView\r\n                        android:id=\"@+id/nombreUsuario\"\r\n                        android:layout_width=\"0dp\"\r\n                        android:layout_height=\"wrap_content\"\r\n                        android:layout_marginTop=\"16dp\"\r\n                        android:gravity=\"center\"\r\n                        android:textColor=\"@color/white\"\r\n                        android:textSize=\"22sp\"\r\n                        android:textStyle=\"bold\"\r\n                        app:layout_constraintEnd_toEndOf=\"parent\"\r\n                        app:layout_constraintStart_toStartOf=\"parent\"\r\n                        app:layout_constraintTop_toBottomOf=\"@id/imgPerfil\"\r\n                        tools:text=\"Milder Gonzales\" />\r\n\r\n                    <TextView\r\n                        android:id=\"@+id/numeroUsuario\"\r\n                        android:layout_width=\"0dp\"\r\n                        android:layout_height=\"wrap_content\"\r\n                        android:layout_marginTop=\"4dp\"\r\n                        android:gravity=\"center\"\r\n                        android:textColor=\"@color/gris_slate_400\"\r\n                        android:textSize=\"14sp\"\r\n                        app:layout_constraintEnd_toEndOf=\"parent\"\r\n                        app:layout_constraintStart_toStartOf=\"parent\"\r\n                        app:layout_constraintTop_toBottomOf=\"@id/nombreUsuario\"\r\n                        tools:text=\"+51 987654321\" />\r\n\r\n                    <com.google.android.material.chip.Chip\r\n                        android:id=\"@+id/verificado\"\r\n                        android:layout_width=\"wrap_content\"\r\n                        android:layout_height=\"wrap_content\"\r\n                        android:layout_marginTop=\"12dp\"\r\n                        android:text=\"Residente Verificado\"\r\n                        android:textColor=\"@color/white\"\r\n                        app:chipBackgroundColor=\"#1A22C55E\"\r\n                        app:chipIcon=\"@drawable/ic_verified\"\r\n                        app:chipIconTint=\"@color/green_safety\"\r\n                        app:chipStrokeWidth=\"0dp\"\r\n                        app:layout_constraintEnd_toEndOf=\"parent\"\r\n                        app:layout_constraintStart_toStartOf=\"parent\"\r\n                        app:layout_constraintTop_toBottomOf=\"@id/numeroUsuario\" />\r\n                </androidx.constraintlayout.widget.ConstraintLayout>\r\n            </com.google.android.material.card.MaterialCardView>\r\n\r\n            <TextView\r\n                android:id=\"@+id/txtMiComunidad\"\r\n                android:layout_width=\"0dp\"\r\n                android:layout_height=\"wrap_content\"\r\n                android:layout_marginStart=\"16dp\"\r\n                android:layout_marginTop=\"24dp\"\r\n                android:text=\"Mi Comunidad\"\r\n                android:textColor=\"@color/white\"\r\n                android:textSize=\"18sp\"\r\n                android:textStyle=\"bold\"\r\n                app:layout_constraintEnd_toEndOf=\"parent\"\r\n                app:layout_constraintStart_toStartOf=\"parent\"\r\n                app:layout_constraintTop_toBottomOf=\"@id/cardUserInfo\" />\r\n\r\n            <androidx.recyclerview.widget.RecyclerView\r\n                android:id=\"@+id/rvComunidades\"\r\n                android:layout_width=\"match_parent\"\r\n                android:layout_height=\"wrap_content\"\r\n                android:layout_marginTop=\"8dp\"\r\n                android:nestedScrollingEnabled=\"false\"\r\n                app:layout_constraintTop_toBottomOf=\"@id/txtMiComunidad\"\r\n                tools:itemCount=\"1\"\r\n                tools:listitem=\"@layout/item_comunidad\" />\r\n\r\n            <com.google.android.material.card.MaterialCardView\r\n                android:id=\"@+id/cardCrearComunidad\"\r\n                android:layout_width=\"match_parent\"\r\n                android:layout_height=\"56dp\"\r\n                android:layout_marginHorizontal=\"16dp\"\r\n                android:layout_marginTop=\"16dp\"\r\n                android:visibility=\"gone\"\r\n                app:cardBackgroundColor=\"@color/bg_card_dark\"\r\n                app:cardCornerRadius=\"12dp\"\r\n                app:cardElevation=\"0dp\"\r\n                app:layout_constraintTop_toBottomOf=\"@id/rvComunidades\"\r\n                app:strokeColor=\"@color/brand_primary\"\r\n                app:strokeWidth=\"1dp\"\r\n                tools:visibility=\"visible\">\r\n\r\n                <TextView\r\n                    android:layout_width=\"match_parent\"\r\n                    android:layout_height=\"match_parent\"\r\n                    android:gravity=\"center\"\r\n                    android:paddingHorizontal=\"24dp\"\r\n                    android:text=\"Crear / Unirse a Comunidad\"\r\n                    android:textColor=\"@color/brand_primary\"\r\n                    android:textSize=\"14sp\"\r\n                    android:textStyle=\"bold\"\r\n                    app:drawableStartCompat=\"@drawable/ic_groups\"\r\n                    app:drawableTint=\"@color/brand_primary\" />\r\n            </com.google.android.material.card.MaterialCardView>\r\n\r\n            <com.google.android.material.card.MaterialCardView\r\n                android:id=\"@+id/cardSalir\"\r\n                android:layout_width=\"match_parent\"\r\n                android:layout_height=\"56dp\"\r\n                android:layout_marginHorizontal=\"16dp\"\r\n                android:layout_marginTop=\"24dp\"\r\n                app:cardBackgroundColor=\"@color/bg_card_dark\"\r\n                app:cardCornerRadius=\"12dp\"\r\n                app:cardElevation=\"0dp\"\r\n                app:layout_constraintTop_toBottomOf=\"@id/cardCrearComunidad\"\r\n                app:strokeColor=\"@color/border_dark\"\r\n                app:strokeWidth=\"1dp\">\r\n\r\n                <LinearLayout\r\n                    android:layout_width=\"match_parent\"\r\n                    android:layout_height=\"match_parent\"\r\n                    android:gravity=\"center\"\r\n                    android:orientation=\"horizontal\">\r\n\r\n                    <ImageView\r\n                        android:layout_width=\"20dp\"\r\n                        android:layout_height=\"20dp\"\r\n                        android:src=\"@drawable/ic_logout\"\r\n                        app:tint=\"@color/red_alert\" />\r\n\r\n                    <TextView\r\n                        android:layout_width=\"wrap_content\"\r\n                        android:layout_height=\"wrap_content\"\r\n                        android:layout_marginStart=\"8dp\"\r\n                        android:text=\"Cerrar Sesión\"\r\n                        android:textColor=\"@color/red_alert\"\r\n                        android:textStyle=\"bold\" />\r\n                </LinearLayout>\r\n            </com.google.android.material.card.MaterialCardView>\r\n\r\n        </androidx.constraintlayout.widget.ConstraintLayout>\r\n    </androidx.core.widget.NestedScrollView>\r\n\r\n    <androidx.coordinatorlayout.widget.CoordinatorLayout\r\n        android:id=\"@+id/contenedorBarraInferior\"\r\n        android:layout_width=\"match_parent\"\r\n        android:layout_height=\"wrap_content\"\r\n        app:layout_constraintBottom_toBottomOf=\"parent\">\r\n\r\n        <com.google.android.material.bottomappbar.BottomAppBar\r\n            android:id=\"@+id/barraNavegacion\"\r\n            android:layout_width=\"match_parent\"\r\n            android:layout_height=\"65dp\"\r\n            android:backgroundTint=\"@color/bg_card_dark\"\r\n            app:fabAlignmentMode=\"center\"\r\n            app:fabCradleMargin=\"8dp\"\r\n            app:fabCradleRoundedCornerRadius=\"24dp\">\r\n\r\n            <androidx.constraintlayout.widget.ConstraintLayout\r\n                android:layout_width=\"match_parent\"\r\n                android:layout_height=\"match_parent\">\r\n\r\n                <LinearLayout\r\n                    android:id=\"@+id/navBtnInicio\"\r\n                    android:layout_width=\"wrap_content\"\r\n                    android:layout_height=\"wrap_content\"\r\n                    android:layout_marginStart=\"32dp\"\r\n                    android:gravity=\"center\"\r\n                    android:orientation=\"vertical\"\r\n                    app:layout_constraintBottom_toBottomOf=\"parent\"\r\n                    app:layout_constraintStart_toStartOf=\"parent\"\r\n                    app:layout_constraintTop_toTopOf=\"parent\">\r\n\r\n                    <ImageView\r\n                        android:layout_width=\"24dp\"\r\n                        android:layout_height=\"24dp\"\r\n                        android:src=\"@drawable/ic_home\"\r\n                        app:tint=\"@color/gris_slate_500\" />\r\n\r\n                    <TextView\r\n                        android:layout_width=\"wrap_content\"\r\n                        android:layout_height=\"wrap_content\"\r\n                        android:text=\"Inicio\"\r\n                        android:textColor=\"@color/gris_slate_500\"\r\n                        android:textSize=\"10sp\"\r\n                        android:textStyle=\"bold\" />\r\n                </LinearLayout>\r\n\r\n                <LinearLayout\r\n                    android:id=\"@+id/navBtnPerfil\"\r\n                    android:layout_width=\"wrap_content\"\r\n                    android:layout_height=\"wrap_content\"\r\n                    android:layout_marginEnd=\"32dp\"\r\n                    android:gravity=\"center\"\r\n                    android:orientation=\"vertical\"\r\n                    app:layout_constraintBottom_toBottomOf=\"parent\"\r\n                    app:layout_constraintEnd_toEndOf=\"parent\"\r\n                    app:layout_constraintTop_toTopOf=\"parent\">\r\n\r\n                    <ImageView\r\n                        android:layout_width=\"24dp\"\r\n                        android:layout_height=\"24dp\"\r\n                        android:src=\"@drawable/ic_person\"\r\n                        app:tint=\"@color/brand_primary\" />\r\n\r\n                    <TextView\r\n                        android:layout_width=\"wrap_content\"\r\n                        android:layout_height=\"wrap_content\"\r\n                        android:text=\"Perfil\"\r\n                        android:textColor=\"@color/brand_primary\"\r\n                        android:textSize=\"10sp\"\r\n                        android:textStyle=\"bold\" />\r\n                </LinearLayout>\r\n            </androidx.constraintlayout.widget.ConstraintLayout>\r\n        </com.google.android.material.bottomappbar.BottomAppBar>\r\n\r\n        <com.google.android.material.floatingactionbutton.FloatingActionButton\r\n            android:id=\"@+id/fabSOS\"\r\n            android:layout_width=\"wrap_content\"\r\n            android:layout_height=\"wrap_content\"\r\n            android:src=\"@drawable/ic_sos\"\r\n            app:backgroundTint=\"@color/red_sos\"\r\n            app:borderWidth=\"0dp\"\r\n            app:elevation=\"6dp\"\r\n            app:layout_anchor=\"@id/barraNavegacion\"\r\n            app:maxImageSize=\"32dp\"\r\n            app:tint=\"@color/white\" />\r\n    </androidx.coordinatorlayout.widget.CoordinatorLayout>\r\n\r\n</androidx.constraintlayout.widget.ConstraintLayout>
