er mainHandler;\r\n    public PublicacionRepositorio(Context context) {\r\n        this.roomDb = BaseDeDatosApp.obtenerInstancia(context);\r\n        this.db = FirebaseFirestore.getInstance();\r\n        this.storageRef = FirebaseStorage.getInstance().getReference();\r\n        this.executor = Executors.newSingleThreadExecutor();\r\n        this.mainHandler = new Handler(Looper.getMainLooper());\r\n    }\r\n    public void obtenerMisComunidades(String usuarioId, CallbackComunidades callback) {\r\n        executor.execute(() -> {\r\n            List<Membresia> membresias = roomDb.daoMembresia().obtenerPorUsuario(usuarioId);\r\n            List<String> idsComunidades = new ArrayList<>();\r\n            for (Membresia m : membresias) idsComunidades.add(m.comunidadId);\r\n            mainHandler.post(() -> callback.exito(idsComunidades));\r\n        });\r\n    }\r\n    public void crearPostOfflineFirst(Publicacion pub, Uri uriImagen, SimpleCallback callback) {\r\n        pub.sincronizado = 0;\r\n        MultimediaPublicacion multi = null;\r\n        if (uriImagen != null) {\r\n            multi = new MultimediaPublicacion();\r\n            multi.multimediaId = UUID.randomUUID().toString();\r\n            multi.publicacionId = pub.publicacionId;\r\n            multi.rutaLocal = uriImagen.toString();\r\n            multi.tipoMime = \"image/jpeg\";\r\n            multi.fechaCreacion = pub.fechaCreacion;\r\n            multi.sincronizado = 0;\r\n        }\r\n        MultimediaPublicacion finalMulti = multi;\r\n        executor.execute(() -> {\r\n            roomDb.daoPublicacion().insertar(pub);\r\n            if (finalMulti != null) roomDb.daoMultimediaPublicacion().insertar(finalMulti);\r\n            mainHandler.post(() -> callback.exito(\"¡Publicado exitosamente!\"));\r\n        });\r\n        if (finalMulti != null) {\r\n            subirFotoYPostNube(pub, finalMulti, uriImagen, callback);\r\n        } else {\r\n            subirPostNubeSoloTexto(pub, callback);\r\n        }\r\n    }\r\n    private void subirFotoYPostNube(Publicacion pub, MultimediaPublicacion multi, Uri uri, SimpleCallback callback) {\r\n        String nombreArchivo = multi.multimediaId + \".jpg\";\r\n        StorageReference fotoRef = storageRef.child(\"multimedia/\" + nombreArchivo);\r\n        fotoRef.putFile(uri)\r\n                .addOnSuccessListener(task -> fotoRef.getDownloadUrl()\r\n                        .addOnSuccessListener(urlDescarga -> {\r\n                            multi.url = urlDescarga.toString();\r\n                            multi.rutaStorage = \"multimedia/\" + nombreArchivo;\r\n                            multi.sincronizado = 1;\r\n                            pub.sincronizado = 1;\r\n                            WriteBatch batch = db.batch();\r\n                            batch.set(db.collection(\"publicaciones\").document(pub.publicacionId), pub);\r\n                            batch.set(db.collection(\"multimedia_publicaciones\").document(multi.multimediaId), multi);\r\n                            batch.commit()\r\n                                    .addOnSuccessListener(a -> executor.execute(() -> {\r\n                                        roomDb.daoPublicacion().actualizar(pub);\r\n                                        roomDb.daoMultimediaPublicacion().actualizar(multi);\r\n                                    }))\r\n                                    .addOnFailureListener(e -> mainHandler.post(() -> callback.error(\"Error en batch: \" + e.getMessage())));\r\n                        })\r\n                        .addOnFailureListener(e -> mainHandler.post(() -> callback.error(\"Error en URL: \" + e.getMessage())))\r\n                )\r\n                .addOnFailureListener(e -> mainHandler.post(() -> callback.error(\"Error en upload: \" + e.getMessage())));\r\n    }\r\n    private void subirPostNubeSoloTexto(Publicacion pub, SimpleCallback callback) {\r\n        pub.sincronizado = 1;\r\n        db.collection(\"publicaciones\").document(pub.publicacionId).set(pub)\r\n                .addOnSuccessListener(a -> executor.execute(() -> roomDb.daoPublicacion().actualizar(pub)))\r\n                .addOnFailureListener(e -> mainHandler.post(() -> callback.error(\"Error en set: \" + e.getMessage())));\r\n    }\r\n    public void cargarFeed(List<String> comunidades, CallbackListadoPublicaciones callback) {\r\n        if (comunidades.isEmpty()) {\r\n            mainHandler.post(() -> callback.error(\"Sin comunidades\"));\r\n            return;\r\n        }\r\n        executor.execute(() -> {\r\n            List<PublicacionDTO> feedLocal = new ArrayList<>();\r\n            for (String comId : comunidades) {\r\n                List<Publicacion> pubsLocal = roomDb.daoPublicacion().obtenerMuroComunidad(comId, 50);\r\n                for (Publicacion p : pubsLocal) {\r\n                    List<MultimediaPublicacion> multis = roomDb.daoMultimediaPublicacion().ObtenerFotosPublicacion(p.publicacionId);\r\n                    MultimediaPublicacion m = multis.isEmpty() ? null : multis.get(0);\r\n                    Usuario autor = roomDb.daoUsuario().obtenerPorId(p.usuarioId);\r\n                    if (autor == null) sincronizarAutor(p.usuarioId);\r\n                    String nombreAutor = autor != null ? autor.nombres : \"Vecino\";\r\n                    feedLocal.add(new PublicacionDTO(p, m, nombreAutor));\r\n                }\r\n            }\r\n            mainHandler.post(() -> callback.exito(feedLocal));\r\n        });\r\n        db.collection(\"publicaciones\")\r\n                .whereIn(\"comunidadId\", comunidades)\r\n                .orderBy(\"fechaCreacion\", Query.Direction.DESCENDING)\r\n                .limit(50)\r\n                .addSnapshotListener((snapsPubs, e) -> {\r\n                    if (e != null || snapsPubs == null) {\r\n                        mainHandler.post(() -> callback.error(\"Error en snapshot: \" + (e != null ? e.getMessage() : \"Snaps null\")));\r\n                        return;\r\n                    }\r\n                    List<String> pubIds = new ArrayList<>();\r\n                    for (QueryDocumentSnapshot doc : snapsPubs) pubIds.add(doc.getId());\r\n                    db.collection(\"multimedia_publicaciones\")\r\n                            .whereIn(\"publicacionId\", pubIds)\r\n                            .get()\r\n                            .addOnCompleteListener(taskMulti -> {\r\n                                if (!taskMulti.isSuccessful()) {\r\n                                    mainHandler.post(() -> callback.error(\"Error en multimedia: \" + taskMulti.getException().getMessage()));\r\n                                    return;\r\n                                }\r\n                                armarFeedNube(snapsPubs, taskMulti.getResult(), callback);\r\n                            });\r\n                });\r\n    }\r\n    private void armarFeedNube(QuerySnapshot snapsPubs, QuerySnapshot snapsMulti, CallbackListadoPublicaciones callback) {\r\n        Map<String, MultimediaPublicacion> mapaMulti = new HashMap<>();\r\n        if (snapsMulti != null) {\r\n            for (QueryDocumentSnapshot d : snapsMulti) {\r\n                MultimediaPublicacion m = d.toObject(MultimediaPublicacion.class);\r\n                if (m != null) mapaMulti.put(m.publicacionId, m);\r\n            }\r\n        }\r\n        executor.execute(() -> {\r\n            List<PublicacionDTO> feedNube = new ArrayList<>();\r\n            for (QueryDocumentSnapshot doc : snapsPubs) {\r\n                Publicacion pub = doc.toObject(Publicacion.class);\r\n                if (pub == null) continue;\r\n                pub.sincronizado = 1;\r\n                MultimediaPublicacion multi = mapaMulti.get(pub.publicacionId);\r\n                if (multi != null) multi.sincronizado = 1;\r\n                roomDb.daoPublicacion().insertar(pub);\r\n                if (multi != null) roomDb.daoMultimediaPublicacion().insertar(multi);\r\n                Usuario autor = roomDb.daoUsuario().obtenerPorId(pub.usuarioId);\r\n                if (autor == null) sincronizarAutor(pub.usuarioId);\r\n                autor = roomDb.daoUsuario().obtenerPorId(pub.usuarioId); // Reload after sync\r\n                String nombreAutor = autor != null ? autor.nombres : \"Vecino\";\r\n                feedNube.add(new PublicacionDTO(pub, multi, nombreAutor));\r\n            }\r\n            mainHandler.post(() -> callback.exito(feedNube));\r\n        });\r\n    }\r\n    private void sincronizarAutor(String usuarioId) {\r\n        db.collection(\"usuarios\").document(usuarioId).get()\r\n                .addOnSuccessListener(doc -> {\r\n                    Usuario autor = doc.toObject(Usuario.class);\r\n                    if (autor != null) {\r\n                        autor.sincronizado = 1;\r\n                        executor.execute(() -> roomDb.daoUsuario().insertar(autor));\r\n                    }\r\n                })\r\n                .addOnFailureListener(e -> {}); // Silencioso, \"Vecino\" si falla\r\n    }\r\n    public void marcarUtil(String id, SimpleCallback callback) {\r\n        db.collection(\"publicaciones\").document(id)\r\n                .update(\"contadorUtil\", com.google.firebase.firestore.FieldValue.increment(1))\r\n                .addOnSuccessListener(aVoid -> {\r\n                    executor.execute(() -> {\r\n                        Publicacion pub = roomDb.daoPublicacion().obtenerPorId(id);\r\n                        if (pub != null) {\r\n                            pub.contadorUtil += 1;\r\n                            roomDb.daoPublicacion().actualizar(pub);\r\n                        }\r\n                    });\r\n                    callback.exito(\"Listo\");\r\n                })\r\n                .addOnFailureListener(e -> callback.error(e.getMessage()));\r\n    }\r\n}
