suario\"\r\n        app:layout_constraintTop_toTopOf=\"parent\">\r\n\r\n      <TextView\r\n          android:layout_width=\"wrap_content\"\r\n          android:layout_height=\"wrap_content\"\r\n          android:text=\"Muro de Seguridad\"\r\n          android:textColor=\"@color/white\"\r\n          android:textSize=\"17sp\"\r\n          android:textStyle=\"bold\" />\r\n\r\n      <TextView\r\n          android:layout_width=\"wrap_content\"\r\n          android:layout_height=\"wrap_content\"\r\n          android:text=\"Barrio seguro\"\r\n          android:textColor=\"@color/gris_slate_400\"\r\n          android:textSize=\"12sp\" />\r\n    </LinearLayout>\r\n\r\n    <ImageView\r\n        android:id=\"@+id/btnNotificaciones\"\r\n        android:layout_width=\"24dp\"\r\n        android:layout_height=\"24dp\"\r\n        android:src=\"@drawable/ic_notifications\"\r\n        app:tint=\"@color/white\"\r\n        app:layout_constraintBottom_toBottomOf=\"parent\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        app:layout_constraintTop_toTopOf=\"parent\" />\r\n\r\n  </androidx.constraintlayout.widget.ConstraintLayout>\r\n\r\n  <androidx.core.widget.NestedScrollView\r\n      android:layout_width=\"match_parent\"\r\n      android:layout_height=\"0dp\"\r\n      android:clipToPadding=\"false\"\r\n      android:fillViewport=\"true\"\r\n      app:layout_constraintTop_toBottomOf=\"@id/layoutCabecera\"\r\n      app:layout_constraintBottom_toTopOf=\"@id/contenedorBarraInferior\">\r\n\r\n    <LinearLayout\r\n        android:layout_width=\"match_parent\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:orientation=\"vertical\"\r\n        android:paddingBottom=\"16dp\">\r\n\r\n      <com.google.android.material.card.MaterialCardView\r\n          android:id=\"@+id/cardCrearPublicacion\"\r\n          android:layout_width=\"match_parent\"\r\n          android:layout_height=\"wrap_content\"\r\n          android:layout_margin=\"16dp\"\r\n          app:cardB