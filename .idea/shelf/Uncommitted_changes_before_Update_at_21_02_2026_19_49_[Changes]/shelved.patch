<+>package ingenieriasistemas.mildergd.appalertaprevencioncomunitaria.repositorio;\r\n\r\nimport android.content.Context;\r\nimport android.net.Uri;\r\nimport android.os.Handler;\r\nimport android.os.Looper;\r\n\r\nimport com.google.firebase.firestore.FirebaseFirestore;\r\nimport com.google.firebase.firestore.Query;\r\nimport com.google.firebase.firestore.QueryDocumentSnapshot;\r\nimport com.google.firebase.storage.FirebaseStorage;\r\nimport com.google.firebase.storage.StorageReference;\r\n\r\nimport java.util.ArrayList;\r\nimport java.util.HashMap;\r\nimport java.util.List;\r\nimport java.util.Map;\r\nimport java.util.UUID;\r\nimport java.util.concurrent.ExecutorService;\r\nimport java.util.concurrent.Executors;\r\n\r\nimport ingenieriasistemas.mildergd.appalertaprevencioncomunitaria.db.BaseDeDatosApp;\r\nimport ingenieriasistemas.mildergd.appalertaprevencioncomunitaria.modelos.MultimediaPublicacion;\r\nimport ingenieriasistemas.mildergd.appalertaprevencioncomunitaria.modelos.Publicacion;\r\nimport ingenieriasistemas.mildergd.appalertaprevencioncomunitaria.modelos.dto.PublicacionDTO;\r\nimport ingenieriasistemas.mildergd.appalertaprevencioncomunitaria.repositorio.callback.CallbackListadoPublicaciones;\r\nimport ingenieriasistemas.mildergd.appalertaprevencioncomunitaria.repositorio.callback.SimpleCallback;\r\n\r\npublic class PublicacionRepositorio {\r\n    private final FirebaseFirestore db;\r\n    private final StorageReference storageRef;\r\n    private final BaseDeDatosApp roomDb;\r\n    private final ExecutorService executor;\r\n    private final Handler mainHandler;\r\n\r\n    public PublicacionRepositorio(Context context) {\r\n        this.roomDb = BaseDeDatosApp.obtenerInstancia(context);\r\n        this.db = FirebaseFirestore.getInstance();\r\n        this.storageRef = FirebaseStorage.getInstance().getReference();\r\n        this.executor = Executors.newSingleThreadExecutor();\r\n        this.mainHandler = new Handler(Looper.getMainLooper());\r\n    }\r\n\r\n    public void crearPost(Publicacion publicacion, Uri uriImagen, SimpleCallback callback){\r\n        if(uriImagen != null){\r\n            String nombreArchivo = UUID.randomUUID().toString() + \".jpg\";\r\n            StorageReference fotoRef = storageRef.child(\"multimedia_publicaciones/\" + nombreArchivo);\r\n\r\n            fotoRef.putFile(uriImagen).addOnSuccessListener(taskSnapshot -> {\r\n                fotoRef.getDownloadUrl().addOnSuccessListener(uriDescarga ->{\r\n                    //LLenamos la tabla multimedia\r\n                    MultimediaPublicacion multimedia = new MultimediaPublicacion();\r\n                    multimedia.multimediaId = UUID.randomUUID().toString();\r\n                    multimedia.publicacionId = publicacion.publicacionId;\r\n                    multimedia.rutaStorage = fotoRef.getPath();\r\n                    multimedia.url  = uriDescarga.toString();\r\n                    multimedia.tipoMime = \"image/jpeg\";\r\n                    multimedia.fechaCreacion = System.currentTimeMillis();\r\n                    multimedia.sincronizado = 1;\r\n                    guardarEnNubeYLocal(publicacion, multimedia, callback);\r\n                });\r\n            }).addOnFailureListener(e -> callback.error(\"Error al subir imagen: \" + e.getMessage()));\r\n        }\r\n        else{\r\n            guardarEnNubeYLocal(publicacion, null, callback);\r\n        }\r\n\r\n    }\r\n\r\n    public void guardarEnNubeYLocal(Publicacion pub, MultimediaPublicacion multi, SimpleCallback callback){\r\n        //Guardar publicación en Firestore\r\n        db.collection(\"publicaciones\").document(pub.publicacionId).set(pub)\r\n                .addOnSuccessListener(aVoid -> {\r\n                    //Si hay una imagen guardamos en FireStore también\r\n                    if(multi != null){\r\n                        db.collection(\"multimedia_publicaciones\").document(multi.multimediaId).set(multi)\r\n                                .addOnSuccessListener(aVoid2 -> sincronizarRoom(pub, multi, callback));\r\n                    }\r\n                    else{\r\n                        sincronizarRoom(pub, null, callback);\r\n                    }\r\n                })\r\n                .addOnFailureListener( e -> callback.error(\"Error en nube\" + e.getMessage()));\r\n    }\r\n\r\n    private void sincronizarRoom(Publicacion pub, MultimediaPublicacion multi, SimpleCallback callback) {\r\n        executor.execute( () -> {\r\n            pub.sincronizado = 1;\r\n            roomDb.daoPublicacion().insertar(pub);\r\n            if(multi != null){\r\n                roomDb.daoMultimediaPublicacion().insertar(multi);\r\n            }\r\n            mainHandler.post( () -> callback.exito(\"¡Publicado correctamente!\"));\r\n        });\r\n    }\r\n\r\n    //Cargr muro en tiempo real\r\n    public void escucharFeed(String comunidadId, CallbackListadoPublicaciones callbackListadoPublicaciones){\r\n        db.collection(\"publicaciones\")\r\n                .whereEqualTo(\"comunidadId\", comunidadId)\r\n                .orderBy(\"fechaCreacion\", Query.Direction.DESCENDING)\r\n                .addSnapshotListener( (snapshotPubs, e) ->{\r\n                    if(e != null){\r\n                        callbackListadoPublicaciones.error(e.getMessage());\r\n                        return;\r\n                    }\r\n                    if(snapshotPubs == null || snapshotPubs.isEmpty()){\r\n                        callbackListadoPublicaciones.exito(new ArrayList<>());\r\n                        return;\r\n                    }\r\n\r\n                    db.collection(\"multimedia_publicaciones\")\r\n                            .get()\r\n                            .addOnSuccessListener( snapshotMultimedia ->{\r\n                                Map<String, MultimediaPublicacion> mapaMultimedia = new HashMap<>();\r\n                                for(QueryDocumentSnapshot docMulti : snapshotMultimedia){\r\n                                    MultimediaPublicacion m = docMulti.toObject(MultimediaPublicacion.class);\r\n                                    mapaMultimedia.put(m.publicacionId, m);\r\n                                }\r\n\r\n                                List<PublicacionDTO> listaFeed = new ArrayList<>();\r\n\r\n                                for(QueryDocumentSnapshot docPub : snapshotPubs){\r\n                                    Publicacion pub = docPub.toObject(Publicacion.class);\r\n                                    MultimediaPublicacion multi = mapaMultimedia.get(pub.publicacionId);\r\n                                    listaFeed.add(new PublicacionDTO(pub, multi, \"Vecino\"));\r\n                                }\r\n                                callbackListadoPublicaciones.exito(listaFeed);\r\n                            });\r\n                });\r\n    }\r\n\r\n    public void marcarUtil (String publicacionId, SimpleCallback callback){\r\n        db.collection(\"publicaciones\").document(publicacionId)\r\n                .update(\"contadorUtil\", com.google.firebase.firestore.FieldValue.increment(1))\r\n                .addOnSuccessListener(aVoid -> callback.exito(\"¡Marcado como útil!\"))\r\n                .addOnFailureListener( e -> callback.error(e.getMessage()));\r\n    }\r\n\r\n}\r\n
