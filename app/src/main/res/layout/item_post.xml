<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/bg_card_dark"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/border_dark"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgAvatarPerfil"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            android:src="@drawable/ic_logo_user"
            app:strokeColor="@color/border_dark"
            app:strokeWidth="1dp" />

        <TextView
            android:id="@+id/txtNombreUsuario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgAvatarPerfil"
            app:layout_constraintTop_toTopOf="@id/imgAvatarPerfil"
            tools:text="Usuario" />

        <TextView
            android:id="@+id/txtEtiquetaTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#1A137FEC"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            app:layout_constraintStart_toStartOf="@id/txtNombreUsuario"
            app:layout_constraintTop_toBottomOf="@id/txtNombreUsuario"
            tools:text="Aviso" />

        <TextView
            android:id="@+id/txtTiempoPublicacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="@color/gris_slate_400"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/txtEtiquetaTipo"
            app:layout_constraintStart_toEndOf="@id/txtEtiquetaTipo"
            app:layout_constraintTop_toTopOf="@id/txtEtiquetaTipo"
            tools:text="• Hace 2h" />

        <TextView
            android:id="@+id/txtContenidoPost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="5dp"
            android:textColor="@color/gris_slate_100"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgAvatarPerfil"
            tools:text="Contenido de la publicación..." />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMapaPost"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_dark"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/txtContenidoPost"
            tools:visibility="visible">
            
            <com.google.android.gms.maps.MapView
                android:id="@+id/mapViewPost"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:liteMode="true" />
                
            <View
                android:id="@+id/mapOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgContenidoMultimedia"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardMapaPost"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Large"
            app:strokeColor="@color/border_dark"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/layoutAcciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/imgContenidoMultimedia"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUtil"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                android:text="Útil"
                android:textColor="@color/gris_slate_400"
                android:textSize="13sp"
                app:icon="@drawable/ic_like"
                app:iconSize="18dp"
                app:iconTint="@color/gris_slate_400" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
