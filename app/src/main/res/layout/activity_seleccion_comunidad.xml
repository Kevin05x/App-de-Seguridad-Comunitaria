<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <TextView
        android:id="@+id/tvSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:text="Elige tu Comunidad"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSelectSub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Para recibir y enviar alertas, debes pertenecer a un grupo vecinal."
        android:textColor="@color/gris_slate_400"
        app:layout_constraintTop_toBottomOf="@id/tvSelect" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardUnirse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="#1C2127"
        app:cardCornerRadius="16dp"
        app:strokeColor="@color/border_dark"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectSub">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tengo un código de invitación"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:boxBackgroundColor="#111418"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeWidth="0dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtCodigoUnion"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="B4RR10"
                    android:gravity="center"
                    android:textAllCaps="true"
                    android:textColor="@color/brand_primary"
                    android:textStyle="bold" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnirseGrupo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:text="Unirse a Grupo Existente"
                android:backgroundTint="@color/brand_primary"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvO"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="O SI ERES LÍDER VECINAL"
        android:textColor="@color/gris_slate_500"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardUnirse" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCrearGrupo"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="Crear Nueva Comunidad"
        android:textColor="@color/white"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_home_work"
        app:iconGravity="textStart"
        app:iconTint="@color/white"
        app:strokeColor="@color/border_dark"
        app:layout_constraintTop_toBottomOf="@id/tvO" />

</androidx.constraintlayout.widget.ConstraintLayout>